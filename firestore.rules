rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: user owns this document
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Profiles: users can only read/write their own profile
    match /profiles/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        // Prevent role and plan_tier from being changed client-side
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role", "plan_tier", "stripe_customer_id"]);
    }

    // Startups — the document ID IS the owner's uid (startups/{uid}), so we
    // check ownership by the path. This works even when the doc doesn't exist
    // yet (a fresh owner reading their own empty profile), which a
    // resource.data-based rule would wrongly deny and hang the client.
    match /startups/{startupId} {
      allow create: if isOwner(startupId) && request.resource.data.owner_uid == request.auth.uid;
      allow read, update, delete: if isOwner(startupId);
      // Investors / others can read discoverable startups
      allow read: if isAuth() && resource.data.is_discoverable == true;

      // Business plans: subcollection, startup-owner only
      match /plans/{planId} {
        allow read, write: if isAuth()
          && get(/databases/$(database)/documents/startups/$(startupId)).data.owner_uid == request.auth.uid;
      }

      // Job roles: owner writes, authenticated talent reads open roles
      match /roles/{roleId} {
        allow read: if isAuth() && resource.data.is_open == true;
        allow write: if isAuth()
          && get(/databases/$(database)/documents/startups/$(startupId)).data.owner_uid == request.auth.uid;
      }
    }

    // Business plans (top-level, per user). Owner only for now; the external
    // teaser version becomes shareable in a later phase.
    match /businessplans/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Projects: creator-owned. Anyone authenticated can browse; only owner mutates.
    match /projects/{projectId} {
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isAuth();
      allow update, delete: if isAuth() && resource.data.ownerId == request.auth.uid;
    }

    // Portfolios: talent-owned nested items
    match /portfolios/{uid}/items/{itemId} {
      allow read, write: if isOwner(uid);
    }

    // Talent profiles: owner reads/writes, startups read to match
    match /talent/{uid} {
      allow read, write: if isOwner(uid);
      allow read: if isAuth(); // startups can browse
    }

    // Applications: talent creates, startup owner reads
    match /applications/{appId} {
      allow create: if isAuth() && request.resource.data.talent_uid == request.auth.uid;
      allow read: if isAuth() && (
        resource.data.talent_uid == request.auth.uid
        // Startup owner reads via server-side only (Admin SDK bypasses rules)
      );
    }

    // Investor profiles: owner only (never public)
    match /investors/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Investor interests: investor creates, startup owner reads via Admin SDK
    match /investor_interests/{id} {
      allow create: if isAuth() && request.resource.data.investor_uid == request.auth.uid;
      allow read: if isAuth() && resource.data.investor_uid == request.auth.uid;
    }

    // Workspaces: created by the Admin SDK (server) which bypasses these rules.
    // Members read/write the workspace and its sub-collections (kanban tasks,
    // milestones, team, AI log). Membership is proven by having a member doc.
    match /workspaces/{workspaceId} {
      function isMember() {
        return isAuth()
          && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
      }

      allow read: if isMember();
      allow update, delete: if isAuth() && resource.data.ownerId == request.auth.uid;

      match /tasks/{taskId} {
        allow read, write: if isMember();
      }
      match /sprints/{sprintId} {
        allow read, write: if isMember();
      }
      match /milestones/{milestoneId} {
        allow read, write: if isMember();
      }
      match /ailog/{logId} {
        allow read, write: if isMember();
      }
      match /members/{memberId} {
        // A member can read the roster; owner manages membership.
        allow read: if isMember();
        allow write: if isAuth()
          && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
