rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Startup logos — owner writes, everyone reads
    match /startups/{startupId}/logo {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == resource.metadata.owner_uid
        && request.resource.size < 2 * 1024 * 1024  // 2 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Data rooms — only startup owner and investors with explicit interest
    match /startups/{startupId}/dataroom/{fileName} {
      allow read: if request.auth != null;  // enforced server-side via Admin SDK
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024; // 50 MB max
    }

    // Talent avatars — owner only
    match /talent/{uid}/avatar {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
